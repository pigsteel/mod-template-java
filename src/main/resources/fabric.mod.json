{
  "schemaVersion": 1,
  "id": "examplemod",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "You!"
  ],
  "contact": {
    "sources": "",
    "issues": ""
  },
  "icon": "assets/icon.png",
  "license": "${mod_license}",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.example.examplemod.fabric.FabricEntrypoint"
    ],
    "client": [
      "com.example.examplemod.fabric.FabricClientEntrypoint"
    ],
    "fabric-datagen": [
      "com.example.examplemod.fabric.datagen.FabricDataGeneratorEntrypoint"
    ]
  },
  "mixins": [
    "examplemod.mixins.json"
  ],
  "depends": {
    "fabric-api": "*",
    "minecraft": "${minecraft_version_range}"
  }
}